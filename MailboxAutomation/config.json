{
  "AzureAd": {
    "TenantId": "1234",
    "ClientId": "1234",
    "CertPath": "/opt/ap-automation/graphcert/graph.crt",
    "KeyPath": "/opt/ap-automation/graphcert/graph.key"
  },
  "Email": {
    "SimulateMove":  true,
    "TargetMailbox": "accounts@mydomain.com",
    "BatchSize": 20,
    "MinImageSizeBytes": 30000,
    "TestFromEnabled": true,
    "TestFromAddress": "kroy@belltechlogix.com",
    "KeyWordExceptions": [
      "statement",
      "statements",
      "past due",
      "past-due",
      "pastdue"
    ],
    "AllowedExtensions": [
      ".pdf",
      ".tif",
      ".tiff",
      ".jpg",
      ".jpeg",
      ".xlsx",
      ".csv",
      ".doc",
      ".docx"
    ],
    "GenericDomains": [
      "gmail.com",
      "yahoo.com",
      "hotmail.com",
      "comcast.net",
      "aol.com",
      "outlook.com",
      "icloud.com",
      "msn.com"
    ],
    "InternalDomains": [
      "mydomain.com"
    ]
  },
  "Paths": {
    "SimulateSMB": true,
    "Staging": "/opt/ap-automation/staging",
    "LogFolder": "/opt/ap-automation/logs",
    "Runtime_Log": "/opt/ap-automation/logs/Runtime.log",
    "Error_Log": "/opt/ap-automation/logs/Error.log",
    "SMBDestination": "/mnt/apauto",
    "CSVPath": "/opt/ap-automation/configs/AP_Vendor_List.csv"
  },
  "Logging": {
    "Verbose": true,
    "Runtime": true,
    "Circular": true,
    "Log_Size": "50MB"
  }
}